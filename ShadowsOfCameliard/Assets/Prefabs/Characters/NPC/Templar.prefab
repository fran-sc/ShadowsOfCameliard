  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 43aa5ec69253ef06d9b550dd595b2451, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::CharacterAI
  idleStepDuration: 0.5
  talkLineWhenSpawn: "\u201C\xA1Sir Lancelot! Toma este arco. Si tu espada no alcanza
    al enemigo, que tu pulso lo encuentre desde lejos.\u201D"
  talkLines:
  - "\u201CSigue avanzando, caballero. La torre resistir\xE1 cuanto pueda. Salva
    a la reina de las garras de la oscuridad.\u201D"
  - '"No te detengas, caballero. Deja esta muralla en nuestras manos.  Tu camino
    conduce a la reina, no a esta batalla." '
  isHealer: 1
  healAmount: 1
